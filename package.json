{
  "name": "example",
  "version": "1.0.0",
  "description": "MOEL press-release based document classifier (department + main topics)",
  "main": "src/classify.js",
  "scripts": {
    "scrape:moel": "node src/scraper.js --years 3 --out data/moel_press_releases_3y.json",
    "build:law": "node src/build-law-departments.js --output data/moel_legal_departments.json",
    "build:model": "node src/build-model.js --input data/moel_press_releases_3y.json --output model/moel_doc_classifier.json --legal data/moel_legal_departments.json",
    "classify": "node src/classify.js --model model/moel_doc_classifier.json --legal data/moel_legal_departments.json",
    "pipeline": "npm run scrape:moel && npm run build:law && npm run build:model",
    "serve": "node src/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "iconv-lite": "^0.7.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5"
  }
}
