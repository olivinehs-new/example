{
  "version": 2,
  "functions": {
    "api/classify.js": {
      "includeFiles": [
        "model/**/*.json",
        "data/moel_legal_departments.json"
      ]
    },
    "api/meta.js": {
      "includeFiles": [
        "model/**/*.json",
        "data/moel_legal_departments.json"
      ]
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/app.js", "destination": "/public/app.js" },
    { "source": "/styles.css", "destination": "/public/styles.css" }
  ]
}
